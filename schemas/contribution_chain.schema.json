{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contribution Chain Output",
  "type": "object",
  "required": ["status", "module_id", "module_name", "input_summary", "structured_output", "next_input", "assumptions", "uncertainty_log", "evidence_requirements", "reviewer_risks", "revision_hooks", "trace_context"],
  "properties": {
    "schema_version": { "type": "string" },
    "project_id": { "type": "string" },
    "status": { "$ref": "#/$defs/status" },
    "module_id": { "const": "04_contribution_argumentation" },
    "module_name": { "const": "Contribution Argumentation" },
    "input_summary": { "$ref": "#/$defs/input_summary" },
    "structured_output": {
      "type": "object",
      "required": ["central_thesis", "contributions", "contribution_to_problem_links", "contribution_to_theory_links", "required_validation", "unsafe_claims_removed", "safer_wording_map"],
      "properties": {
        "central_thesis": { "type": "string" },
        "contributions": { "type": "array", "items": { "$ref": "#/$defs/contribution" } },
        "contribution_to_problem_links": { "type": "array", "items": { "type": "object" } },
        "contribution_to_theory_links": { "type": "array", "items": { "type": "object" } },
        "required_validation": { "type": "array", "items": { "type": "object" } },
        "unsafe_claims_removed": { "type": "array", "items": { "type": "string" } },
        "safer_wording_map": { "type": "array", "items": { "type": "object" } },
        "evidence_requirements": { "type": "array" },
        "uncertainty_log": { "type": "array" }
      },
      "additionalProperties": false
    },
    "next_input": {
      "type": "object",
      "required": ["central_thesis", "contributions", "contribution_links", "required_validation", "reviewer_risks", "evidence_policy", "trace_context"],
      "properties": {
        "central_thesis": { "type": "string" },
        "contributions": { "type": "array" },
        "contribution_links": { "type": "array" },
        "required_validation": { "type": "array" },
        "reviewer_risks": { "type": "array" },
        "evidence_policy": { "$ref": "#/$defs/evidence_policy" },
        "trace_context": { "$ref": "#/$defs/trace_context" }
      },
      "additionalProperties": false
    },
    "assumptions": { "type": "array", "items": { "$ref": "#/$defs/evidence_item" } },
    "uncertainty_log": { "type": "array", "items": { "$ref": "#/$defs/uncertainty_item" } },
    "evidence_requirements": { "type": "array", "items": { "$ref": "#/$defs/evidence_requirement" } },
    "reviewer_risks": { "type": "array", "items": { "$ref": "#/$defs/reviewer_risk" } },
    "revision_hooks": { "type": "array", "items": { "$ref": "#/$defs/revision_hook" } },
    "trace_context": { "$ref": "#/$defs/trace_context" }
  },
  "additionalProperties": false,
  "$defs": {
    "status": { "enum": ["draft", "complete", "validated", "needs_revision"] },
    "evidence_status": { "enum": ["verified", "user_provided", "inferred", "needs_literature_verification", "speculative"] },
    "contribution": { "type": "object", "required": ["contribution_id", "contribution_type", "contribution_claim", "linked_problem_id", "linked_problem_property", "linked_theoretical_positioning", "linked_domain_tension_id", "required_evidence", "required_experiment", "likely_reviewer_question", "defense_strategy", "unsafe_wording_to_avoid", "safer_wording", "boundary_of_claim", "evidence_status"], "properties": { "contribution_id": { "type": "string" }, "contribution_type": { "type": "string" }, "contribution_claim": { "type": "string" }, "linked_problem_id": { "type": "string" }, "linked_problem_property": { "type": "string" }, "linked_theoretical_positioning": { "type": "string" }, "linked_domain_tension_id": { "type": "string" }, "required_evidence": { "type": "array", "items": { "type": "string" } }, "required_experiment": { "type": "array", "items": { "type": "string" } }, "likely_reviewer_question": { "type": "string" }, "defense_strategy": { "type": "string" }, "unsafe_wording_to_avoid": { "type": "array", "items": { "type": "string" } }, "safer_wording": { "type": "string" }, "boundary_of_claim": { "type": "string" }, "evidence_status": { "$ref": "#/$defs/evidence_status" } }, "additionalProperties": false },
    "evidence_item": { "type": "object", "required": ["statement", "evidence_status"], "properties": { "id": { "type": "string" }, "statement": { "type": "string" }, "evidence_status": { "$ref": "#/$defs/evidence_status" }, "source": { "type": "string" } }, "additionalProperties": false },
    "input_summary": { "type": "object", "required": ["direct_upstream_module_id", "summary"], "properties": { "direct_upstream_module_id": { "type": ["string", "null"] }, "summary": { "type": "string" }, "consumed_files": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
    "evidence_policy": { "type": "object", "required": ["default_literature_status", "allowed_statuses"], "properties": { "default_literature_status": { "const": "needs_literature_verification" }, "allowed_statuses": { "type": "array", "items": { "$ref": "#/$defs/evidence_status" } } }, "additionalProperties": false },
    "trace_context": { "type": "object", "required": ["source_module_ids", "domain_tension_ids", "problem_ids", "theory_element_ids", "contribution_ids", "lineage"], "properties": { "source_module_ids": { "type": "array", "items": { "type": "string" } }, "domain_tension_ids": { "type": "array", "items": { "type": "string" } }, "problem_ids": { "type": "array", "items": { "type": "string" } }, "theory_element_ids": { "type": "array", "items": { "type": "string" } }, "contribution_ids": { "type": "array", "items": { "type": "string" } }, "lineage": { "type": "array", "items": { "type": "object" } } }, "additionalProperties": false },
    "uncertainty_item": { "type": "object", "required": ["item", "evidence_status", "action_required"], "properties": { "item": { "type": "string" }, "evidence_status": { "$ref": "#/$defs/evidence_status" }, "action_required": { "type": "string" } }, "additionalProperties": false },
    "evidence_requirement": { "type": "object", "required": ["requirement_id", "requirement", "evidence_status"], "properties": { "requirement_id": { "type": "string" }, "requirement": { "type": "string" }, "evidence_status": { "$ref": "#/$defs/evidence_status" } }, "additionalProperties": false },
    "reviewer_risk": { "type": "object", "required": ["risk_id", "question", "mitigation", "evidence_status"], "properties": { "risk_id": { "type": "string" }, "question": { "type": "string" }, "mitigation": { "type": "string" }, "evidence_status": { "$ref": "#/$defs/evidence_status" } }, "additionalProperties": false },
    "revision_hook": { "type": "object", "required": ["field", "action", "affects"], "properties": { "field": { "type": "string" }, "action": { "type": "string" }, "affects": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false }
  }
}
